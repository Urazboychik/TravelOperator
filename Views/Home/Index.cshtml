@model DashboardViewModel
@{
    ViewData["Title"] = "TravelOperator";
}

<section class="landing-hero">
    <div>
        <p class="eyebrow">Современная туристическая платформа</p>
        <h1>Платформа для продажи туров и управления туроператорским бизнесом</h1>
        <p>Один продукт, но два понятных сценария: красивая витрина и кабинет для туристов, а также мощная B2B-платформа для предпринимателей, агентств и туроператоров.</p>
        <div class="hero-actions">
            <a class="action-button" asp-controller="Home" asp-action="Customer">Я турист</a>
            <a class="action-button ghost-link" asp-controller="Home" asp-action="Business">Я предприниматель</a>
            <a class="action-button ghost-link" asp-controller="Home" asp-action="Admin" data-admin-gate>Открыть админку</a>
        </div>
    </div>
    <div class="landing-visual">
        <img src="https://commons.wikimedia.org/wiki/Special:FilePath/Kapadokya_balon_turları.jpg?width=1200" alt="Travel platform preview" loading="eager" decoding="async" fetchpriority="high" />
        <div class="floating-live-card">
            <span class="pulse-dot"></span>
            <strong><span data-live-number>37</span> заявок онлайн</strong>
            <small>демо-активность обновляется в реальном времени</small>
        </div>
    </div>
</section>

<section class="audience-grid">
    <article>
        <span>01</span>
        <h2>Для туристов</h2>
        <p>Поиск туров, красивые предложения, бронирование, оплата, документы, бонусы и поддержка.</p>
        <a asp-controller="Home" asp-action="Customer">Перейти в витрину</a>
    </article>
    <article>
        <span>02</span>
        <h2>Для предпринимателей</h2>
        <p>CRM, B2B продажи, квоты, поставщики, финансы, аналитика, маркетинг и операционная панель.</p>
        <a asp-controller="Home" asp-action="Business">Посмотреть платформу</a>
    </article>
    <article>
        <span>03</span>
        <h2>Каталог туров</h2>
        <p>Реальные популярные направления: Байкал, Алтай, Камчатка, Сочи, Дагестан, Карелия и другие.</p>
        <a asp-controller="Home" asp-action="Offers">Показать больше</a>
    </article>
</section>

<section class="live-strip">
    <div><strong data-live-number>128</strong><span>активных просмотров</span></div>
    <div><strong>7,8 млн ₽</strong><span>воронка продаж</span></div>
    <div><strong data-live-number>24</strong><span>новых бронирования</span></div>
    <div><strong data-live-number>92</strong><span>партнера в сети</span></div>
</section>

<div class="modal-backdrop" id="request-modal" hidden>
    <section class="modal-card">
        <button type="button" class="modal-close" data-close>×</button>
        <p class="eyebrow">Заявка на тур</p>
        <h2>Оставить заявку</h2>
        <form class="admin-form">
            <label>Имя<input type="text" placeholder="Как к вам обращаться" /></label>
            <label>Направление<input type="text" placeholder="Например, Байкал или Сочи" /></label>
            <button type="button" data-demo-submit>Отправить заявку</button>
        </form>
    </section>
</div>

<div class="toast" id="toast" hidden>Действие выполнено в демо-режиме</div>
