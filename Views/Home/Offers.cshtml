@model DashboardViewModel
@{
    ViewData["Title"] = "Каталог туров";
    var tours = TourCatalog.Items;
}

<section class="catalog-hero public-hero">
    <div>
        <p class="eyebrow">Каталог туров</p>
        <h1>Каталог реальных популярных направлений</h1>
        <p>Карточки сфокусированы на продаже: направление, длительность, цена, визуальный образ и быстрый запрос.</p>
    </div>
    <div class="live-booking-card"><span class="pulse-dot"></span><strong><span data-live-number>63</span> просмотра каталога</strong><small>обновляется автоматически</small></div>
</section>

<section class="catalog-grid">
    @foreach (var tour in tours)
    {
        <article class="catalog-card">
            <div class="tour-cover">
                <img src="@TourImageAssets.Catalog(tour.Images[0])" alt="@tour.Name" loading="lazy" decoding="async" width="480" height="320" />
                <span class="rating-pill">★ @tour.Rating</span>
                <span class="season-pill">@tour.Season</span>
            </div>
            <div class="tour-body">
                <div class="tour-meta-row">
                    <span class="badge">@tour.Duration</span>
                    <span>@tour.Level</span>
                </div>
                <h2>@tour.Name</h2>
                <p class="tour-place">⌖ @tour.Place</p>
                <p>@tour.Description</p>
                <div class="tour-tags">
                    @foreach (var tag in tour.Tags)
                    {
                        <span>@tag</span>
                    }
                </div>
                <footer>
                    <strong>от @tour.Price</strong>
                    <a class="action-button" asp-controller="Home" asp-action="Tour" asp-route-id="@tour.Slug">Подробнее</a>
                </footer>
            </div>
        </article>
    }
</section>

<div class="modal-backdrop" id="request-modal" hidden>
    <section class="modal-card">
        <button type="button" class="modal-close" data-close>×</button>
        <p class="eyebrow">Детали тура</p>
        <h2>Получить программу тура</h2>
        <form class="admin-form">
            <label>Ваш email<input type="email" placeholder="mail@example.com" /></label>
            <label>Комментарий<input type="text" placeholder="Даты, состав группы, пожелания" /></label>
            <button type="button" data-form-submit>Отправить</button>
        </form>
    </section>
</div>

<div class="toast" id="toast" hidden>Программа тура отправлена</div>
