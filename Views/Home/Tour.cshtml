            "https://commons.wikimedia.org/wiki/Special:FilePath/Avachinsky_Volcano_in_Kamchatka_in_Russia_-_2787374.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Koryaksky_and_Avachinsky_volcanoes_from_the_ISS.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/WW_Avachinsky_Bay_and_surroundings.png?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Kamchatka_three_brothers_rdfr.jpg?width=1200"
        },
        "dagestan-canyon" => new[]
        {
            "https://commons.wikimedia.org/wiki/Special:FilePath/Sarykum_Sand_Dune.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/%D0%94%D0%B0%D0%B3%D0%B5%D1%81%D1%82%D0%B0%D0%BD%2C_%D0%B4%D0%BE%D0%BB%D0%B8%D0%BD%D0%B0_%D1%80%D0%B5%D0%BA%D0%B8_%D0%A1%D1%83%D0%BB%D0%B0%D0%BA.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/%D0%AD%D0%BA%D1%81%D0%BA%D1%83%D1%80%D1%81%D0%B8%D1%8F_%D0%B2_%D0%94%D0%B0%D0%B3%D0%B5%D1%81%D1%82%D0%B0%D0%BD_(56).jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Caspian_Sea_near_Derbent.jpg?width=1200"
        },
        "karelia-weekend" => new[]
        {
            "https://commons.wikimedia.org/wiki/Special:FilePath/0398Ga._Ruskeala_Park.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/0518Ac._Karelia._Ruskeala_Mountain_park.jpg?width=1200",
