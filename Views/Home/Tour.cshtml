@model TourCatalogItem
@{
    ViewData["Title"] = Model.Name;
    var galleryFallbacks = string.Join("|", Model.Images);
    var programFallbacks = string.Join("|", Model.ProgramImages.Distinct());
}

<section class="tour-detail-hero">
    <div>
        <a class="back-link" asp-controller="Home" asp-action="Offers">← Все туры</a>
        <p class="eyebrow">@Model.Place</p>
        <h1>@Model.Name</h1>
        <p>@Model.Description</p>
        <div class="tour-tags">
            <span>★ @Model.Rating</span>
            <span>@Model.Duration</span>
            <span>@Model.Season</span>
            <span>@Model.Level</span>
        </div>
        <div class="hero-actions">
            <button type="button" data-open="request-modal">Забронировать</button>
            <a class="action-button ghost-link" href="#program">Смотреть программу</a>
        </div>
    </div>
    <div class="detail-gallery">
        <img class="main-detail-image" src="@Model.Images[0]" alt="@Model.Name" loading="eager" decoding="async" fetchpriority="high" data-image-fallbacks="@galleryFallbacks" />
        <div>
            @foreach (var image in Model.Images.Skip(1))
            {
                <img src="@image" alt="@Model.Name" loading="lazy" decoding="async" data-image-fallbacks="@galleryFallbacks" />
            }
        </div>
    </div>
</section>

<section class="tour-detail-grid">
    <article class="panel">
        <p class="eyebrow">О туре</p>
        <h2>Что вас ждет</h2>
        <p>@Model.Description</p>
        <div class="tour-tags">
            @foreach (var tag in Model.Tags)
            {
                <span>@tag</span>
            }
        </div>
    </article>

    <article class="panel price-panel">
        <p class="eyebrow">Стоимость</p>
        <h2>от @Model.Price</h2>
        <p>@Model.Includes</p>
        <button type="button" data-open="request-modal">Получить программу</button>
    </article>
</section>

<section id="program" class="panel">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Маршрут по дням</p>
            <h2>Программа тура</h2>
        </div>
    </div>
    <div class="program-interactive" data-program-viewer>
        <div class="program-timeline">
            @for (var i = 0; i < Model.Program.Length; i++)
            {
                var dayNumber = i + 1;
                var dayImage = Model.ProgramImages[i];
                <button
                    type="button"
                    class="program-day @(i == 0 ? "active" : "")"
                    data-day-title="День @dayNumber"
                    data-day-text="@Model.Program[i]"
                    data-day-image="@dayImage"
                    data-day-image-index="@i"
                    data-day-fallbacks="@programFallbacks">
                    <span>@dayNumber</span>
                    <div>
                        <strong>День @dayNumber</strong>
                        <p>@Model.Program[i]</p>
                    </div>
                </button>
            }
        </div>
        <article class="program-preview">
            <img src="@Model.ProgramImages[0]" alt="@Model.Name - день 1" loading="lazy" decoding="async" data-program-image data-image-fallbacks="@programFallbacks" />
            <div>
                <p class="eyebrow">Выбранный день</p>
                <h3 data-program-title>День 1</h3>
                <p data-program-text>@Model.Program[0]</p>
                <div class="tour-tags">
                    <span>@Model.Place</span>
                    <span>@Model.Duration</span>
                    <span>@Model.Level</span>
                </div>
            </div>
        </article>
    </div>
</section>

<div class="modal-backdrop" id="request-modal" hidden>
    <section class="modal-card">
        <button type="button" class="modal-close" data-close>×</button>
        <p class="eyebrow">Заявка на бронирование</p>
        <h2>@Model.Name</h2>
        <form class="admin-form">
            <label>Ваш email<input type="email" placeholder="mail@example.com" /></label>
            <label>Количество туристов<input type="number" placeholder="2" /></label>
            <button type="button" data-form-submit>Отправить заявку</button>
        </form>
    </section>
</div>

<div class="toast" id="toast" hidden>Заявка по туру отправлена</div>
