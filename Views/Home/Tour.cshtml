        },
        "cappadocia-premium" => new[]
        {
            "https://commons.wikimedia.org/wiki/Special:FilePath/Entrance_of_a_cave_Hotel_Room_in_G%C3%B6reme.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/G%C3%B6reme_Valley_in_Cappadocia.jpg?width=1200",
