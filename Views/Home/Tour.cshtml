            "https://commons.wikimedia.org/wiki/Special:FilePath/Sighnaghi%2C_Georgia.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Mtskheta%2C_Georgia.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Alazani_Valley%2C_Georgia.jpg?width=1200"
        },
        "uzbekistan-silk-road" => new[]
        {
            "https://commons.wikimedia.org/wiki/Special:FilePath/Registan_square_Samarkand%2C_Uzbekistan%2C_at_night.jpg?width=1200",
            "https://commons.wikimedia.org/wiki/Special:FilePath/Bukhara%2C_Uzbekistan_74_(103).jpg?width=1200",
